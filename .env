APP_ENV=local
APP_URL=http://localhost:8080
APP_PORT=8080
APP_KEY=local-change-me-32-character-secret-key
APP_TRUST_PROXY=false

DB_HOST=db
DB_PORT=3306
DB_NAME=seller_reviews
DB_USER=seller_user
DB_PASS=seller_pass
DB_ROOT_PASSWORD=root_pass
DB_PUBLIC_PORT=3307

RUN_MIGRATIONS=true
RUN_SEEDS=true
SEED_SAMPLE_REVIEWS=true
SPAM_COOLDOWN_SECONDS=180

ADMIN_USERNAME=admin
ADMIN_FULL_NAME=Administrador

