# App
APP_ENV=production
APP_URL=https://seu-dominio.com
APP_KEY=troque-por-uma-chave-longa-e-aleatoria
APP_TRUST_PROXY=true
SESSION_NAME=seller_rating_session
SPAM_COOLDOWN_SECONDS=180

# Database: use DATABASE_URL OR the DB_* variables below.
# Examples:
# DATABASE_URL=mysql://usuario:senha@host:3306/banco
# DATABASE_URL=mysql://usuario:senha@host:3306/banco?sslmode=require
DATABASE_URL=
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_SSL_MODE=
DB_SSL_CA=

# Deploy/runtime
RUN_MIGRATIONS=true
RUN_SEEDS=true
SEED_SAMPLE_REVIEWS=false

# Admin seed. Generate with:
# docker compose exec app php -r "echo password_hash('sua_senha', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_USERNAME=admin
ADMIN_FULL_NAME=Administrador
ADMIN_PASSWORD_HASH=

# Optional vendor image paths
NICOLAS_PHOTO_PATH=images/nicolas-placeholder.svg
GABRIEL_PHOTO_PATH=images/gabriel-placeholder.svg

